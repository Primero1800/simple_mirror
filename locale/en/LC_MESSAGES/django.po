#: accounts/forms.py:9 accounts/forms.py:21
#: accounts/templates/accounts/login.html:19
#: accounts/templates/accounts/register.html:25
msgid "Пароль"
msgstr "Password"

#: accounts/forms.py:10
#: accounts/templates/accounts/password_reset_confirm.html:16
#: accounts/templates/accounts/register.html:29
msgid "Повторите пароль"
msgstr "Repeat password"

#: accounts/forms.py:15
msgid "Пароли не совпадают"
msgstr "Passwords do not match"

#: accounts/templates/accounts/login.html:3
msgid "Вход"
msgstr "Sign In"

#: accounts/templates/accounts/login.html:6
#: accounts/templates/accounts/password_reset_complete.html:10
#: accounts/templates/accounts/register.html:35
#: mirror/templates/mirror/index.html:273
msgid "Войти"
msgstr "Sign In"

#: accounts/templates/accounts/login.html:22
#: accounts/templates/accounts/register.html:32
msgid "Продолжить"
msgstr "Continue"

#: accounts/templates/accounts/login.html:25
msgid "Нет аккаунта?"
msgstr "No account?"

#: accounts/templates/accounts/login.html:25
msgid "Зарегистрироваться"
msgstr "Sign Up"

#: accounts/templates/accounts/login.html:26
#: accounts/templates/accounts/password_reset_form.html:6
msgid "Забыли пароль?"
msgstr "Forgot password?"

#: accounts/templates/accounts/login.html:27
#: accounts/templates/accounts/password_reset_complete.html:13
#: accounts/templates/accounts/password_reset_confirm.html:36
#: accounts/templates/accounts/password_reset_done.html:12
#: accounts/templates/accounts/password_reset_form.html:19
msgid "Продолжить без входа"
msgstr "Continue without signing in"

#: accounts/templates/accounts/password_reset_complete.html:3
#: accounts/templates/accounts/password_reset_complete.html:6
msgid "Пароль изменён"
msgstr "Password changed"

#: accounts/templates/accounts/password_reset_complete.html:7
msgid "Теперь можно войти с новым паролем."
msgstr "You can now sign in with your new password."

#: accounts/templates/accounts/password_reset_confirm.html:3
#: accounts/templates/accounts/password_reset_confirm.html:6
#: accounts/templates/accounts/password_reset_confirm.html:12
msgid "Новый пароль"
msgstr "New password"

#: accounts/templates/accounts/password_reset_confirm.html:12
#: accounts/templates/accounts/register.html:25
msgid "минимум 8 символов"
msgstr "minimum 8 characters"

#: accounts/templates/accounts/password_reset_confirm.html:26
msgid "Сохранить пароль"
msgstr "Save password"

#: accounts/templates/accounts/password_reset_confirm.html:30
msgid "Ссылка недействительна или устарела."
msgstr "The link is invalid or has expired."

#: accounts/templates/accounts/password_reset_confirm.html:32
msgid "Запросить новую ссылку"
msgstr "Request a new link"

#: accounts/templates/accounts/password_reset_done.html:3
msgid "Письмо отправлено"
msgstr "Email sent"

#: accounts/templates/accounts/password_reset_done.html:6
msgid "Проверьте почту"
msgstr "Check your inbox"

#: accounts/templates/accounts/password_reset_done.html:8
msgid ""
"Если аккаунт с таким email существует, мы отправили ссылку для сброса "
"пароля. Ссылка действительна 24 часа."
msgstr ""
"If an account with that email exists, we sent a password reset link. "
"The link is valid for 24 hours."

#: accounts/templates/accounts/password_reset_done.html:11
#: accounts/templates/accounts/password_reset_form.html:18
msgid "Вернуться ко входу"
msgstr "Back to sign in"

#: accounts/templates/accounts/password_reset_email.html:2
msgid ""
"Вы получили это письмо, потому что кто-то запросил сброс пароля для вашего "
"аккаунта на сайте Mirror."
msgstr ""
"You received this email because someone requested a password reset "
"for your Mirror account."

#: accounts/templates/accounts/password_reset_email.html:4
msgid "Перейдите по ссылке, чтобы задать новый пароль:"
msgstr "Follow the link to set a new password:"

#: accounts/templates/accounts/password_reset_email.html:8
msgid "Ссылка действительна 24 часа."
msgstr "The link is valid for 24 hours."

#: accounts/templates/accounts/password_reset_email.html:10
msgid "Если вы не запрашивали сброс пароля — просто проигнорируйте это письмо."
msgstr "If you did not request a password reset, simply ignore this email."

#: accounts/templates/accounts/password_reset_form.html:3
msgid "Восстановление пароля"
msgstr "Password reset"

#: accounts/templates/accounts/password_reset_form.html:7
msgid "Введите email — пришлём ссылку для сброса."
msgstr "Enter your email — we will send you a reset link."

#: accounts/templates/accounts/password_reset_form.html:15
msgid "Отправить ссылку"
msgstr "Send link"

#: accounts/templates/accounts/password_reset_subject.txt:1
msgid "Mirror — сброс пароля"
msgstr "Mirror — password reset"

#: accounts/templates/accounts/register.html:3
#: mirror/templates/mirror/index.html:275
msgid "Регистрация"
msgstr "Sign Up"

#: accounts/templates/accounts/register.html:6
msgid "Создать аккаунт"
msgstr "Create account"

#: accounts/templates/accounts/register.html:35
msgid "Уже есть аккаунт?"
msgstr "Already have an account?"

#: accounts/templates/accounts/register.html:36
msgid "Продолжить без регистрации"
msgstr "Continue without signing up"

#: accounts/templates/accounts/verify.html:3
msgid "Подтверждение"
msgstr "Verification"

#: accounts/templates/accounts/verify.html:6
msgid "Введите код"
msgstr "Enter code"

#: accounts/templates/accounts/verify.html:7
msgid "Отправили 4-значный код на"
msgstr "We sent a 4-digit code to"

#: accounts/templates/accounts/verify.html:25
msgid "Код действителен"
msgstr "Code valid for"

#: accounts/templates/accounts/verify.html:29
msgid "Отправить код повторно"
msgstr "Resend code"

#: accounts/templates/accounts/verify.html:32
msgid "Подтвердить"
msgstr "Confirm"

#: accounts/templates/accounts/verify.html:101
msgid "Отправляем…"
msgstr "Sending…"

#: accounts/templates/accounts/verify.html:102
msgid "Ошибка. Попробуйте ещё раз."
msgstr "Error. Please try again."

#: accounts/views.py:39 accounts/views.py:72
msgid "Не удалось отправить код. Попробуйте позже."
msgstr "Could not send verification code. Please try again later."

#: accounts/views.py:78
msgid "Неверный email или пароль"
msgstr "Invalid email or password"

#: accounts/views.py:111
msgid "Неверный или истёкший код"
msgstr "Invalid or expired code"

#: accounts/views.py:141
msgid "Сессия истекла"
msgstr "Session expired"

#: accounts/views.py:145
msgid "Пользователь не найден"
msgstr "User not found"

#: accounts/views.py:150
msgid "Не удалось отправить код"
msgstr "Could not send code"

#: mirror/templates/mirror/index.html:271
msgid "Выйти"
msgstr "Sign Out"

#: mirror/templates/mirror/index.html:279
msgid "Запрашиваем разрешения"
msgstr "Requesting permissions"

#: mirror/templates/mirror/index.html:304
msgid "Снимок"
msgstr "Snapshot"

#: mirror/templates/mirror/index.html:305
msgid "Кружок"
msgstr "Circle"

#: mirror/templates/mirror/index.html:307
msgid "Запись"
msgstr "Record"

#: mirror/templates/mirror/index.html:309
msgid "Стоп"
msgstr "Stop"
