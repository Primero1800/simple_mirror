DEBUG=True
SECRET_KEY=your-secret-key

# ── OTP ────────────────────────────────────────────────────────────────────────

OTP_LIFETIME_SECONDS=60
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=30
LOGIN_MAX_ATTEMPTS=3
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=0.5
EMAIL_THREAD_POOL_SIZE=4

# ── Health check ──────────────────────────────────────────────────────────────

HEALTH_CHECK_TIMEOUT_SEC=5

# ── Database ───────────────────────────────────────────────────────────────────

DB_ENGINE=django.db.backends.postgresql
POSTGRES_HOST=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=6432
POSTGRES_DB=mirror

# ── Redis ──────────────────────────────────────────────────────────────────────

REDIS_HOST=redis
REDIS_PORT=6379

# ── Email ──────────────────────────────────────────────────────────────────────

EMAIL_TIMEOUT=5
EMAIL_HOST=smtp.beget.com
EMAIL_PORT=2525
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=admin@primero1800.ru
EMAIL_HOST_PASSWORD=your-email-password
